{
  "name": "server",
  "version": "1.0.0",
  "description": "InsightMirror 后端服务",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "cross-env NODE_ENV=development nodemon -r dotenv/config -r tsconfig-paths/register src/start.ts",
    "build": "prisma generate && tsc && tsc-alias",
    "start": "cross-env NODE_ENV=production node dist/start.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^3.0.3",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.10",
    "@types/pg": "^8.11.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.2.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}
