generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  username     String?   @unique
  passwordHash String?   @map("password_hash")
  avatar       String?
  email        String?   @unique
  nickname     String?
  sessions     Session[]
  posts        Post[]

  @@index([username])
  @@index([email])
  @@map("users")
}

model Session {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  type       String?
  token      String   @unique
  accessAt   DateTime @updatedAt
  sessionKey String?
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model Setting {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  name      String    @unique
  data      Json?
  remark    String?

  @@index([name])
  @@map("settings")
}

model Post {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String   @map("author_id")
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([createdAt])
  @@map("posts")
}

model StateGridCrawlerWatermark {
  id            String    @id @default(uuid())
  source        String
  scopeType     String    @map("scope_type")
  scopeKey      String    @map("scope_key")
  cursorValue   String?   @map("cursor_value")
  status        String    @default("active")
  lastAttemptAt DateTime? @map("last_attempt_at")
  lastSuccessAt DateTime? @map("last_success_at")
  errorMessage  String?   @map("error_message")
  version       Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([source, scopeType, scopeKey])
  @@map("state_grid_crawler_watermarks")
}

model StateGridCrawlTask {
  id           String               @id @default(uuid())
  source       String
  sourceRunId  String?              @map("source_run_id")
  taskType     String               @map("task_type")
  bizKey       String               @map("biz_key")
  parentTaskId String?              @map("parent_task_id")
  payload      Json?
  status       String               @default("pending")
  attemptCount Int                  @default(0) @map("attempt_count")
  maxAttempts  Int                  @default(5) @map("max_attempts")
  nextRetryAt  DateTime?            @map("next_retry_at")
  errorCode    String?              @map("error_code")
  errorMessage String?              @map("error_message")
  startedAt    DateTime?            @map("started_at")
  finishedAt   DateTime?            @map("finished_at")
  workerId     String?              @map("worker_id")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  parentTask   StateGridCrawlTask?  @relation("StateGridCrawlTaskToStateGridCrawlTask", fields: [parentTaskId], references: [id])
  childTasks   StateGridCrawlTask[] @relation("StateGridCrawlTaskToStateGridCrawlTask")

  @@unique([source, taskType, bizKey])
  @@map("state_grid_crawl_tasks")
}

model StateGridNoticeRaw {
  id            String                  @id @default(uuid())
  source        String
  sourceRunId   String?                 @map("source_run_id")
  noticeId      String                  @map("notice_id")
  noticeType    String?                 @map("notice_type")
  orgId         String?                 @map("org_id")
  listApi       String?                 @map("list_api")
  listBatchKey  String?                 @map("list_batch_key")
  publishedAt   DateTime?               @map("published_at")
  title         String?
  rawListJson   Json?                   @map("raw_list_json")
  rawMetaJson   Json?                   @map("raw_meta_json")
  isSuspect     Boolean                 @default(false) @map("is_suspect")
  suspectReason String?                 @map("suspect_reason")
  firstSeenAt   DateTime                @default(now()) @map("first_seen_at")
  lastSeenAt    DateTime                @updatedAt @map("last_seen_at")
  status        String                  @default("discovered")
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")
  details       StateGridNoticeDetail[]
  files         StateGridNoticeFile[]

  @@unique([source, noticeId])
  @@map("state_grid_notice_raws")
}

model StateGridNoticeDetail {
  id            String             @id @default(uuid())
  noticeRawId   String             @map("notice_raw_id")
  source        String
  sourceRunId   String?            @map("source_run_id")
  noticeId      String             @map("notice_id")
  orgId         String?            @map("org_id")
  detailApi     String             @map("detail_api")
  rawDetailJson Json?              @map("raw_detail_json")
  rawHtml       String?            @map("raw_html") @db.Text
  contentType   String?            @map("content_type")
  isSuspect     Boolean            @default(false) @map("is_suspect")
  suspectReason String?            @map("suspect_reason")
  fetchStatus   String             @default("pending") @map("fetch_status")
  errorCode     String?            @map("error_code")
  errorMessage  String?            @map("error_message")
  fetchedAt     DateTime?          @map("fetched_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  noticeRaw     StateGridNoticeRaw @relation(fields: [noticeRawId], references: [id], onDelete: Cascade)

  @@unique([source, noticeId, detailApi])
  @@map("state_grid_notice_details")
}

model StateGridNoticeFile {
  id               String             @id @default(uuid())
  noticeRawId      String             @map("notice_raw_id")
  source           String
  sourceRunId      String?            @map("source_run_id")
  noticeId         String             @map("notice_id")
  orgId            String?            @map("org_id")
  fileRole         String             @map("file_role")
  sourceApi        String             @map("source_api")
  sourceFileId     String             @map("source_file_id")
  fileName         String?            @map("file_name")
  ext              String?
  mimeType         String?            @map("mime_type")
  sizeBytes        Int?               @map("size_bytes")
  checksumSha256   String?            @map("checksum_sha256")
  ossBucket        String?            @map("oss_bucket")
  ossKey           String?            @map("oss_key")
  sourceUrl        String?            @map("source_url")
  rawFileMetaJson  Json?              @map("raw_file_meta_json")
  isSuspect        Boolean            @default(false) @map("is_suspect")
  suspectReason    String?            @map("suspect_reason")
  status           String             @default("pending")
  attemptCount     Int                @default(0) @map("attempt_count")
  lastErrorCode    String?            @map("last_error_code")
  lastErrorMessage String?            @map("last_error_message")
  downloadedAt     DateTime?          @map("downloaded_at")
  uploadedAt       DateTime?          @map("uploaded_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  noticeRaw        StateGridNoticeRaw @relation(fields: [noticeRawId], references: [id], onDelete: Cascade)

  @@unique([source, noticeId, sourceApi, sourceFileId])
  @@index([ossKey])
  @@map("state_grid_notice_files")
}
