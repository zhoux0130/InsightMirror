generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  username     String?   @unique
  passwordHash String?   @map("password_hash")
  avatar       String?
  mobile       String?   @unique
  bio          String?
  email        String?   @unique
  nickname     String?
  phone        String?   @unique
  oauths       OAuth[]
  sessions     Session[]
  baskets      Basket[]

  @@index([username])
  @@index([email])
  @@index([mobile])
  @@index([phone])
  @@map("users")
}

model Session {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  type       String?
  token      String   @unique
  accessAt   DateTime @updatedAt
  sessionKey String?
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model OAuth {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  type      String
  openid    String
  unionid   String?
  appid     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([type, openid])
  @@index([unionid])
  @@index([userId, type, appid])
  @@map("oauths")
}

model Setting {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  name      String    @unique
  data      Json?
  remark    String?

  @@index([name])
  @@map("settings")
}

model SecurityMaster {
  symbol     String    @id
  name       String
  market     String    @default("CN") @db.VarChar(4) // CN | US
  exchange   String
  listDate   DateTime? @map("list_date") @db.Date
  delistDate DateTime? @map("delist_date") @db.Date
  listStatus String    @default("listed") @map("list_status")
  source     String    @default("akshare")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([market])
  @@index([exchange])
  @@index([listStatus])
  @@map("security_master")
}

model DailyBar {
  symbol    String
  tradeDate DateTime @map("trade_date") @db.Date
  market    String   @default("CN") @db.VarChar(4) // CN | US
  open      Decimal  @db.Decimal(12, 4)
  high      Decimal  @db.Decimal(12, 4)
  low       Decimal  @db.Decimal(12, 4)
  close     Decimal  @db.Decimal(12, 4)
  volume    BigInt
  amount    Decimal? @db.Decimal(18, 2)
  turnover  Decimal? @db.Decimal(8, 4)
  pctChange Decimal? @map("pct_change") @db.Decimal(8, 4)
  createdAt DateTime @default(now()) @map("created_at")

  @@id([symbol, tradeDate])
  @@index([symbol, tradeDate(sort: Desc)])
  @@index([market, tradeDate(sort: Desc)])
  @@map("daily_bar")
}

model SegmentIndex {
  id             BigInt   @id @default(autoincrement())
  symbol         String
  market         String   @default("CN") @db.VarChar(4) // CN | US
  startDate      DateTime @map("start_date") @db.Date
  endDate        DateTime @map("end_date") @db.Date
  windowSize     Int      @default(60) @map("window_size") @db.SmallInt
  featureVersion String   @default("v1") @map("feature_version")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([symbol, endDate, windowSize, featureVersion])
  @@index([symbol, endDate(sort: Desc)])
  @@index([market])
  @@index([featureVersion])
  @@index([endDate])
  @@map("segment_index")
}

model SegmentFutureLabel {
  segmentId   BigInt    @map("segment_id")
  futureDays  Int       @default(20) @map("future_days") @db.SmallInt
  returnRate  Decimal?  @map("return_rate") @db.Decimal(8, 4)
  maxDrawdown Decimal?  @map("max_drawdown") @db.Decimal(8, 4)
  maxProfit   Decimal?  @map("max_profit") @db.Decimal(8, 4)
  sharpeRatio Decimal?  @map("sharpe_ratio") @db.Decimal(8, 4)
  winFlag     Boolean?  @map("win_flag")
  labelStatus String    @default("pending") @map("label_status")
  filledAt    DateTime? @map("filled_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@id([segmentId])
  @@index([labelStatus])
  @@map("segment_future_label")
}

model FeatureVersionConfig {
  version       String   @id
  description   String?
  featureDim    Int      @map("feature_dim") @db.SmallInt
  featureParams Json     @map("feature_params")
  status        String   @default("active")
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("feature_version_config")
}

model Basket {
  id          String        @id @default(cuid())
  userId      String        @map("user_id")
  market      String        @default("CN") @db.VarChar(4) // CN | US
  name        String
  description String?
  capital     Decimal       @default(100000) @db.Decimal(14, 2)
  status      String        @default("active")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  stocks      BasketStock[]
  rules       BasketRule[]
  positions   Position[]

  @@index([userId])
  @@index([userId, market])
  @@map("baskets")
}

model BasketStock {
  id       String   @id @default(cuid())
  basketId String   @map("basket_id")
  symbol   String
  addedAt  DateTime @default(now()) @map("added_at")
  basket   Basket   @relation(fields: [basketId], references: [id], onDelete: Cascade)

  @@unique([basketId, symbol])
  @@map("basket_stocks")
}

model BasketRule {
  id             String     @id @default(cuid())
  basketId       String     @map("basket_id")
  name           String?
  conditionGroup Json       @map("condition_group")
  enabled        Boolean    @default(true)
  basket         Basket     @relation(fields: [basketId], references: [id], onDelete: Cascade)
  positions      Position[]

  @@map("basket_rules")
}

model Position {
  id          String      @id @default(cuid())
  basketId    String      @map("basket_id")
  symbol      String
  buyDate     DateTime    @map("buy_date") @db.Date
  buyPrice    Decimal     @map("buy_price") @db.Decimal(12, 4)
  shares      Int
  sellDate    DateTime?   @map("sell_date") @db.Date
  sellPrice   Decimal?    @map("sell_price") @db.Decimal(12, 4)
  triggerType String      @default("manual") @map("trigger_type")
  ruleId      String?     @map("rule_id")
  note        String?
  basket      Basket      @relation(fields: [basketId], references: [id], onDelete: Cascade)
  rule        BasketRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([basketId])
  @@index([basketId, symbol])
  @@map("positions")
}

model PipelineRunLog {
  id               BigInt    @id @default(autoincrement())
  runDate          DateTime  @map("run_date") @db.Date
  market           String    @default("CN") @db.VarChar(4) // CN | US
  stepName         String    @map("step_name")
  status           String
  startedAt        DateTime  @map("started_at")
  finishedAt       DateTime? @map("finished_at")
  recordsProcessed Int?      @map("records_processed")
  errorMessage     String?   @map("error_message")

  @@unique([runDate, market, stepName])
  @@map("pipeline_run_log")
}
