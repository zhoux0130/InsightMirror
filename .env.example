# 服务配置
NODE_ENV=production
PORT=3000

# 对外暴露端口 (nginx)
EPORT=80

# 数据库连接 (必填)
DATABASE_URL=postgresql://user:password@host:5432/database

# 安全密钥 (生产环境必填，至少32字符)
WEB_SECRET=your-web-secret-min-32-characters
APP_SECRET=your-app-secret-min-32-characters
JWT_SECRET=your-jwt-secret-min-32-characters
JWT_EXPIRES_IN=7d

# PostgreSQL
POSTGRES_USER=insightmirror
POSTGRES_PASSWORD=insightmirror
POSTGRES_DB=insightmirror
DB_PORT=5432

# Compute Service
COMPUTE_SERVICE_URL=http://localhost:8000
COMPUTE_PORT=8000
DATA_SOURCE=akshare
RAW_DATA_DIR=data/raw
HISTORY_START_DATE=2016-01-01
HISTORY_END_DATE=2026-03-06
HISTORY_ADJUST=
TUSHARE_TOKEN=your_tushare_token_here
